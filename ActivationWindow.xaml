<Window x:Class="NetworkTroubleshooter.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="产品激活" 
        Height="220" 
        Width="420"
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize" 
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
        Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 主标题 -->
        <TextBlock Grid.Row="0" 
                   Text="激活此产品" 
                   FontSize="16" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,8"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"/>

        <!-- 描述性文字 -->
        <TextBlock Grid.Row="1" 
                   Text="输入您的 25 位产品密钥以激活此产品。" 
                   TextWrapping="Wrap" 
                   FontSize="12" 
                   Margin="0,0,0,16"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>

        <!-- 激活码输入区域 -->
        <Border Grid.Row="2" 
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" 
                BorderThickness="1" 
                CornerRadius="2"
                Margin="0,0,0,16">
            <TextBox x:Name="txtActivationCode" 
                     FontSize="12" 
                     Padding="8,6" 
                     Margin="0"
                     VerticalContentAlignment="Center"
                     HorizontalAlignment="Stretch"
                     MaxLength="25" 
                     ToolTip="请输入25位产品密钥"
                     />
        </Border>

        <!-- 按钮区域 -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button x:Name="btnVerify" 
                    Content="下一步" 
                    Width="90" 
                    Height="30" 
                    Margin="0,0,8,0" 
                    Padding="12,0" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="btnVerify_Click"
                    IsDefault="True">
                <Button.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF005A9E" Offset="0"/>
                        <GradientStop Color="#FF005A9E" Offset="1"/>
                    </LinearGradientBrush>
                </Button.BorderBrush>
            </Button>

            <Button x:Name="btnCancel" 
                    Content="取消" 
                    Width="90" 
                    Height="30" 
                    Padding="12,0" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="btnCancel_Click"
                    IsCancel="True"/>
        </StackPanel>

    </Grid>
</Window>