<Window x:Class="NetworkTroubleshooter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows 网络故障诊断" Height="520" Width="600" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F0F0F0" FontFamily="Microsoft YaHei">

    <Window.Resources>
        <Style x:Key="RetroLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#0078D7"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Rectangle x:Name="rectBg" Fill="#E5F3FB" Opacity="0" RadiusX="2" RadiusY="2"/>
                            <Rectangle x:Name="rectBorder" Stroke="#70C0E7" StrokeThickness="1" Opacity="0" RadiusX="2" RadiusY="2"/>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="UIElement.MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="rectBg" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="rectBorder" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="UIElement.MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="rectBg" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="rectBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="rectBg" Property="Fill" Value="#CBE8F6"/>
                                <Setter TargetName="rectBorder" Property="Stroke" Value="#3C7FB1"/>
                                <Setter Property="Foreground" Value="#005697"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0">
                <StackPanel>
                    <TextBlock Text="解决并帮助预防计算机问题" FontSize="11" Foreground="#666666" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="45,15,45,15">

            <StackPanel x:Name="pnlWelcome" Visibility="Visible">
                <StackPanel Orientation="Horizontal" Margin="0,15,0,25">
                    <Image Source="interneticon.png" Width="51" Height="57" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock Text="网络连接验证" FontSize="20" Foreground="#004578" Margin="20,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="    此疑难解答有助于检测并修复连接问题。" 
                           TextWrapping="Wrap" Margin="60,0,0,0" LineHeight="20" Foreground="#333333"/>
                <StackPanel Orientation="Horizontal" Margin="60,25,0,0" Width="419">
                    <TextBlock x:Name="txtAdvanced" Text="高级" Foreground="#0078D7" Cursor="Hand" MouseLeftButtonDown="txtAdvanced_MouseLeftButtonDown" RenderTransformOrigin="1.458,0.301"/>
                    <CheckBox x:Name="chkCreateProxy" Content="创建代理而非VPN" Margin="20,0,0,0" Visibility="Collapsed" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="     发布者: Microsoft Corporation" Margin="60,8,0,0" Foreground="#666666" FontSize="11"/>
            </StackPanel>

            <StackPanel x:Name="pnlProgress" Visibility="Collapsed">
                <TextBlock Text="正在检测问题" FontSize="18" Foreground="#004578" Margin="0,10,0,35"/>
                <TextBlock x:Name="txtStatus" Text="正在扫描本地网关状态..." Margin="0,0,0,12" Foreground="#333333"/>
                <ProgressBar x:Name="pBar" Height="14" BorderBrush="#D0D0D0"/>
            </StackPanel>

            <StackPanel x:Name="pnlResult" Visibility="Collapsed">
                
                <StackPanel Orientation="Horizontal" Margin="0,15,0,25" HorizontalAlignment="Center">
                    <TextBlock Text="已成功接入网络  \@(^O^)@/  " FontSize="35" Foreground="#004578" Margin="20,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                </StackPanel>

                <Grid Height="232" Width="411">
                    <TextBlock HorizontalAlignment="Left" Margin="85,40,0,0" TextWrapping="Wrap" Text="点击查看关于此工具的" VerticalAlignment="Top" FontSize="15" Height="25" Width="150"/>
                    <TextBlock HorizontalAlignment="Left" Margin="104,60,0,0" TextWrapping="Wrap" Text="点击查看我们的" VerticalAlignment="Top" FontSize="15" Height="20" Width="128" Cursor=""/>
                    <TextBlock HorizontalAlignment="Left" Margin="101,80,0,0" TextWrapping="Wrap" Text="欢迎来看视频站：" VerticalAlignment="Top" FontSize="15" Height="20" Width="128" Cursor=""/>
                    <Canvas>
                        <TextBlock HorizontalAlignment="Center" FontSize="15" VerticalAlignment="Center"  Margin="235,40,0,0"> <Hyperlink NavigateUri="http://10.88.202.73/123" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#007ACC" TextDecorations="None">更多信息</Hyperlink>
                        </TextBlock>
                    </Canvas>
                    <Canvas>
                        <TextBlock HorizontalAlignment="Center" FontSize="15" VerticalAlignment="Center" Margin="209,60,0,0"> <Hyperlink NavigateUri="http://10.88.202.73" RequestNavigate="Hyperlink_RequestNavigate"  Foreground="#007ACC" TextDecorations="None">网站</Hyperlink>
                        </TextBlock>
                    </Canvas>
                    <Canvas>
                        <TextBlock HorizontalAlignment="Center" FontSize="15" VerticalAlignment="Center" Margin="213,80,0,0"> <Hyperlink NavigateUri="https://psvideo.duckdns.org/" RequestNavigate="Hyperlink_RequestNavigate"  Foreground="#007ACC" TextDecorations="None">查看</Hyperlink>
                        </TextBlock>
                    </Canvas>
                </Grid>

                <StackPanel Margin="0,20,0,0">
                    <Button Style="{StaticResource RetroLinkButtonStyle}" Click="btnCloseTroubleshooter_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="→" FontFamily="Segoe UISymbol" FontSize="18" Foreground="Green" Margin="0,0,12,0"/>
                            <TextBlock Text="关闭疑难解答" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RetroLinkButtonStyle}" Margin="0,2,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="→" FontFamily="Segoe UISymbol" FontSize="18" Foreground="Green" Margin="0,0,12,0"/>
                            <TextBlock Text="浏览其他选项" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="#E1E1E1" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0">
                <Button x:Name="btnNext" Content="下一步(_N)" Width="90" Height="26" Click="btnNext_Click" IsDefault="True" Background="#F0F0F0" BorderBrush="#ADADAD"/>
                <Button x:Name="btnFinish" Content="完成(_F)" Width="90" Height="26" Visibility="Collapsed" Click="btnCancel_Click" Background="#F0F0F0" BorderBrush="#ADADAD"/>
                <Button x:Name="btnCancel" Content="取消" Width="90" Height="26" Margin="10,0,0,0" Click="btnCancel_Click" IsCancel="True" Background="#F0F0F0" BorderBrush="#ADADAD"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>